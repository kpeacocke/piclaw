---
profile: basic
exclude_paths:
  - .venv/
  - venv/
  - .git/
  - .github/
  - awx/
  - molecule/
  - .pre-commit-config.yaml
skip_list:
  # Variables are scoped to a single-node group; role-level prefixing adds no value here.
  - var-naming[no-role-prefix]
  # Inline reboots are intentional — reboot ordering for hardware config requires explicit control.
  - no-handler
warn_list:
  - fqcn-builtins
